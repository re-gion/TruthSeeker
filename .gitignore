# ============================================
# 根目录 .gitignore - TruthSeeker 项目
# ============================================

# ============================================
# Node.js / Next.js（前端项目）
# ============================================

# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Testing
coverage/
test-results/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# ============================================
# Python / FastAPI（后端项目）
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual environments - 重要：忽略所有虚拟环境
venv/
venv_new/
env/
ENV/
.venv/

# Python distributions
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ============================================
# 环境变量文件（重要：包含敏感信息）
# ============================================

# 根目录环境变量
.env
.env.local
.env.*.local

# 各子项目的环境变量
truthseeker-web/.env.local
truthseeker-web/.env.*.local
truthseeker-api/.env

# ============================================
# IDE 和编辑器
# ============================================

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ============================================
# 操作系统
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================
# 项目特定的临时文件
# ============================================

# 临时测试文件
tmp_*
*.tmp
*.temp
test_*.py

# 日志文件
dev.log
build_output.log
typescript_errors.log

# 字体文件（如果是从外部获取的大型字体）
# truthseeker-web/public/fonts/*.otf
# truthseeker-web/public/fonts/*.ttf
# truthseeker-web/public/fonts/*.woff*

# 截图和录屏
screenshots/
recordings/
*.mp4
*.webm

# ============================================
# Supabase 相关
# ============================================

# Supabase CLI generated files
.supabase/
-supabase/
supabase/.branches/
supabase/.temp/

# ============================================
# Vercel 相关
# ============================================

.vercel

# ============================================
# Docker 相关
# ============================================

docker-compose.override.yml

# ============================================
# 其他工具
# ============================================

# Logs from various tools
logs/

# Package locks (通常应该保留，但如果有冲突可以忽略)
# truthseeker-web/package-lock.json
# truthseeker-web/yarn.lock
# truthseeker-web/pnpm-lock.yaml

# Archives
*.zip
*.tar.gz
*.rar

# ============================================
# 子项目特定的忽略规则
# ============================================

# 前端项目的 node_modules 和构建产物
truthseeker-web/node_modules/
truthseeker-web/.next/
truthseeker-web/out/
truthseeker-web/build/

# 后端项目的虚拟环境和缓存
truthseeker-api/venv/
truthseeker-api/venv_new/
truthseeker-api/__pycache__/
truthseeker-api/**/__pycache__/
truthseeker-api/**/*.pyc

# 文档临时文件
docs/~$*.doc*
docs/~$*.xls*
docs/~$*.ppt*
