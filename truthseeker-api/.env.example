# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=NOT_SET

# AI APIs
REALITY_DEFENDER_API_KEY=
# 兼容旧环境名
# Reality_Defender=
VIRUSTOTAL_API_KEY=
# 兼容旧环境名
# Virus_Total=
# Kimi 调用方式：official 或 coding
KIMI_PROVIDER=official
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6
# Kimi coding plan（OpenAI-compatible；如果填 https://api.kimi.com/coding，代码会自动补 /v1）
KIMI_CODING_API_KEY=
KIMI_CODING_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODING_MODEL=kimi-k2.6
# 兼容旧环境名
# Kimi_API_KEY=
# Kimi_Base_URL=https://api.moonshot.cn/v1
# Kimi_Model=kimi-k2.6
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
# 以下当前未被代码直接使用，保留用于未来 LLM 提供商切换
OPENAI_API_KEY=
QWEN_API_KEY=

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
MAX_ROUNDS=3
CONVERGENCE_THRESHOLD=0.08
