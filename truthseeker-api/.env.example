# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=NOT_SET

# AI APIs
REALITY_DEFENDER_API_KEY=         # Reality Defender，用于音视频 deepfake 检测
AIGC_IMAGE_PROVIDER=sightengine          # 图片 AIGC 检测默认用 Sightengine
AIGC_IMAGE_FALLBACK_PROVIDER=reality_defender    # # Sightengine 不可用时，可回退到 RD
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
VIRUSTOTAL_API_KEY=
DOMAIN_PROVENANCE_ENABLED=true    # 是否启用域名溯源
WHOISXML_API_KEY=
WHOISXML_TIMEOUT_SECONDS=20       # WhoisXML 查询超时时间
TEXT_AIGC_DETECTOR_ENABLED=true   # 是否启用内部文本 AIGC 检测工具
TEXT_AIGC_AI_THRESHOLD=0.6        # 内部文本 AI 概率 >= 该阈值时标记为 AI 生成倾向

# Agent 底层全模态模型：kimi-k2.5 或 mimo
AGENT_LLM_PROVIDER=kimi-k2.5
# TruthSeeker 单次 Agent LLM 回复上限；Kimi/MiMo 都按此限制，默认 4k
AGENT_LLM_MAX_OUTPUT_TOKENS=4096
# K2.5 渠道：official / coding / siliconflow
KIMI_PROVIDER=official
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
# Kimi K2.5 模型能力：输入 text,image,video；上下文 262144 tokens；官方支持 thinking enabled/disabled，本系统固定 disabled；当前输出上限由 AGENT_LLM_MAX_OUTPUT_TOKENS 控制。
# Kimi coding plan（OpenAI-compatible；如果填 https://api.kimi.com/coding，代码会自动补 /v1）
KIMI_CODING_API_KEY=
KIMI_CODING_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODING_MODEL=kimi-k2.5
# Kimi SiliconFlow 渠道
KIMI_SILICONFLOW_API_KEY=
KIMI_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
KIMI_SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.5
# 小米 MiMo Token Plan（OpenAI-compatible；AGENT_LLM_PROVIDER=mimo 时生效）
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# MiMo V2.5 模型能力：输入 text,image；官方上下文 1048576 tokens；官方输出上限 131072 tokens；本系统输出上限由 AGENT_LLM_MAX_OUTPUT_TOKENS 控制。
# MiMo thinking：官方支持 enabled/disabled；默认 enabled。enabled 时官方不支持自定义 temperature，代码按 1.0 传入。
MIMO_THINKING=enabled

EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# 公开案例库 RAG embedding（SiliconFlow OpenAI-compatible embeddings）
CASE_RAG_ENABLED=true
CASE_RAG_TOP_K=5
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
EMBEDDING_DIMENSIONS=1024

# 以下当前未被代码直接使用，保留用于未来 LLM 提供商切换
OPENAI_API_KEY=
QWEN_API_KEY=

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
MAX_ROUNDS=3
CONVERGENCE_THRESHOLD=0.08
